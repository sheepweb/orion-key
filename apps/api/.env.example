# Orion Key API environment example
# 用法（临时启动）：
#   set -a
#   source apps/api/.env.example
#   set +a
#   java -jar apps/api/target/orion-key-1.0.0-SNAPSHOT.jar

SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
DB_URL=jdbc:postgresql://127.0.0.1:5432/orion_key
DB_USERNAME=orion_key
DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_to_a_long_random_string

# Upload
UPLOAD_PATH=/www/wwwroot/orion-key/uploads
UPLOAD_URL_PREFIX=/api/uploads

# Mail
MAIL_ENABLED=false
MAIL_SITE_URL=https://example.com
MAIL_HOST=mail.example.com
MAIL_PORT=465
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=change_me

# Security / CORS
PASSWORD_PLAIN=false
CORS_ALLOWED_ORIGINS=https://example.com,http://localhost:3000
RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1

